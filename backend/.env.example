# ── LLM Provider (choose ONE of the two setups) ──

# A) OpenAI direct
# OPENAI_API_KEY=sk-...

# B) Zhipu / GLM (OpenAI-compatible)
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# OPENAI_API_KEY=YOUR_ZHIPU_KEY

# ── CORS ──
# Comma-separated list of allowed origins (or "*" for any).
# In production, set this to your Vercel URL(s).
# Example: ALLOWED_ORIGINS=https://darwin-meme.vercel.app,https://www.darwin.meme
ALLOWED_ORIGINS=*

# Optional: regex for preview deployments (e.g. *.vercel.app)
# ALLOWED_ORIGIN_REGEX=^https://.*\.vercel\.app$

# ── Runtime ──
# PORT is injected by Railway / Render — leave unset locally.
# PORT=8000

# ── Persistence ──
# Railway Volumes are mounted at /data by convention.
# DATABASE_PATH=/data/darwin_meme.db

# ── Four.meme (optional; only needed to actually execute trades on-chain) ──
# BSC_PRIVATE_KEY=0x...
